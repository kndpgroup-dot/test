<div class="product-gallery">
  <div class="main-image" style="aspect-ratio: 1; border-radius: 16px; overflow: hidden; background: #f3f4f6; position: relative; margin-bottom: 16px;">
    <img id="mainProductImage" src="{{ product.featured_image | img_url: '800x800' }}" alt="{{ product.title }}" style="width: 100%; height: 100%; object-fit: cover;">
    {% if product.compare_at_price > product.price %}
      <div style="position: absolute; top: 16px; right: 16px; background: #ec4899; color: white; padding: 8px 16px; border-radius: 9999px; font-weight: bold;">
        Save {{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}%
      </div>
    {% endif %}
  </div>
  
  <div class="thumbnail-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;">
    {% for image in product.images limit: 4 %}
      <button type="button" onclick="changeMainImage('{{ image | img_url: '800x800' }}', this)" class="thumbnail-btn" style="aspect-ratio: 1; border-radius: 8px; overflow: hidden; border: 2px solid #e5e7eb; background: none; padding: 0; cursor: pointer; transition: border-color 0.3s;">
        <img src="{{ image | img_url: '200x200' }}" alt="View {{ forloop.index }}" style="width: 100%; height: 100%; object-fit: cover;">
      </button>
    {% endfor %}
  </div>
</div>

<script>
function changeMainImage(src, btn) {
  document.getElementById('mainProductImage').src = src;
  document.querySelectorAll('.thumbnail-btn').forEach(b => b.style.borderColor = '#e5e7eb');
  btn.style.borderColor = '#9333ea';
}
</script>