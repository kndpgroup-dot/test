<div class="cart-page">
  <div class="container">
    <h1 class="page-title">Καλάθι Αγορών</h1>

    {% if cart.item_count > 0 %}
      <form action="/cart" method="post" class="cart-form">
        <div class="cart-content">
          <div class="cart-items">
            {% for item in cart.items %}
              <div class="cart-item" data-line="{{ forloop.index }}">
                <div class="cart-item-image">
                  <a href="{{ item.url }}">
                    <img src="{{ item.image | img_url: '200x200' }}" alt="{{ item.title | escape }}">
                  </a>
                </div>

                <div class="cart-item-details">
                  <h3 class="cart-item-title">
                    <a href="{{ item.url }}">{{ item.product.title }}</a>
                  </h3>
                  
                  <div class="cart-item-quantity">
                    <button type="button" class="qty-btn" onclick="updateCartQty({{ forloop.index }}, -1)">-</button>
                    <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" data-line="{{ forloop.index }}">
                    <button type="button" class="qty-btn" onclick="updateCartQty({{ forloop.index }}, 1)">+</button>
                  </div>

                  <div class="cart-item-price">
                    <span class="price">{{ item.final_line_price | money }}</span>
                    <span class="unit-price">{{ item.price | money }} το καθένα</span>
                  </div>

                  <a href="/cart/change?line={{ forloop.index }}&quantity=0" class="cart-item-remove">Αφαίρεση</a>
                </div>
              </div>
            {% endfor %}
          </div>

          <div class="cart-summary">
            <h2>Περίληψη Παραγγελίας</h2>
            
            <div class="cart-summary-row">
              <span>Υποσύνολο</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            
            <div class="cart-summary-row">
              <span>Αποστολή</span>
              <span class="free-shipping">ΔΩΡΕΑΝ</span>
            </div>
            
            <div class="cart-summary-total">
              <span>Σύνολο</span>
              <span>{{ cart.total_price | money }}</span>
            </div>

            <button type="submit" name="checkout" class="btn btn-primary btn-checkout">
              Ολοκλήρωση Αγοράς
            </button>

            <div class="cart-guarantees">
              <div>🚚 Δωρεάν αποστολή σε όλες τις παραγγελίες</div>
              <div>🛡️ Εγγύηση 30 ημερών επιστροφής χρημάτων</div>
              <div>🔒 Ασφαλής ολοκλήρωση αγοράς</div>
            </div>

            <a href="/collections/all" class="continue-shopping">← Συνέχεια αγορών</a>
          </div>
        </div>
      </form>
    {% else %}
      <div class="cart-empty">
        <div class="empty-icon">🛍️</div>
        <h2>Το καλάθι σας είναι άδειο</h2>
        <p>Φαίνεται ότι δεν έχετε προσθέσει ακόμη τίποτα στο καλάθι σας.</p>
        <a href="/collections/all" class="btn btn-primary">Ξεκινήστε τις αγορές</a>
      </div>
    {% endif %}
  </div>
</div>