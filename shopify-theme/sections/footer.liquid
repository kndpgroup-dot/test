<section class="trust-badges" style="background: white; border-top: 1px solid #e5e7eb; border-bottom: 1px solid #e5e7eb; padding: 40px 0;">
  <div class="container" style="max-width: 1400px; margin: 0 auto; padding: 0 20px;">
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; text-align: center;">
      <div>
        <div style="font-size: 48px; margin-bottom: 12px;">🚚</div>
        <h3 style="font-weight: 600; margin-bottom: 4px;">Δωρεάν Αποστολή</h3>
        <p style="color: #6b7280; font-size: 14px;">Σε όλες τις παραγγελίες</p>
      </div>
      <div>
        <div style="font-size: 48px; margin-bottom: 12px;">🛡️</div>
        <h3 style="font-weight: 600; margin-bottom: 4px;">Εγγύηση 30 Ημερών</h3>
        <p style="color: #6b7280; font-size: 14px;">Χωρίς ρίσκο</p>
      </div>
      <div>
        <div style="font-size: 48px; margin-bottom: 12px;">🔄</div>
        <h3 style="font-weight: 600; margin-bottom: 4px;">Εύκολες Επιστροφές</h3>
        <p style="color: #6b7280; font-size: 14px;">Απλή διαδικασία</p>
      </div>
    </div>
  </div>
</section>

<footer class="site-footer" style="background: #f9fafb; padding: 48px 0 24px;">
  <div class="container" style="max-width: 1400px; margin: 0 auto; padding: 0 20px;">
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; margin-bottom: 32px;">
      <div>
        <h4 style="font-weight: 600; margin-bottom: 12px;">Αγορά</h4>
        <p style="color: #6b7280; font-size: 14px;">Ξεχάστε τα κοψίματα, εξανθήματα και ενοχλητικές τρίχες. Δοκιμάστε το Bleame.</p>
      </div>
      <div>
        <h4 style="font-weight: 600; margin-bottom: 12px;">Αξιολογήσεις</h4>
        <p style="color: #6b7280; font-size: 14px;">Ανακαλύψτε τι λένε 12.500+ πελάτες για το Bleame</p>
      </div>
      <div>
        <h4 style="font-weight: 600; margin-bottom: 12px;">Κέντρο Βοήθειας</h4>
        <p style="color: #6b7280; font-size: 14px; margin-bottom: 8px;">Γρήγορη αποστολή από τη Νεβάδα, ΗΠΑ</p>
        <a href="/pages/help-center" style="color: #9333ea; font-weight: 500; font-size: 14px;">Επισκεφθείτε το Κέντρο Βοήθειας →</a>
      </div>
    </div>
    
    <div style="border-top: 1px solid #e5e7eb; padding-top: 24px; display: flex; justify-content: space-between; align-items: center; font-size: 14px; color: #6b7280;">
      <div style="display: flex; gap: 24px;">
        <span>🚚</span>
        <span>🛡️</span>
        <span>🔄</span>
      </div>
      <p>© {{ 'now' | date: "%Y" }} {{ shop.name }}. Όλα τα δικαιώματα διατηρούνται.</p>
      <a href="/account/login" style="color: #9333ea; font-weight: 500;">Σύνδεση</a>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Υποσέλιδο",
  "settings": []
}
{% endschema %}
